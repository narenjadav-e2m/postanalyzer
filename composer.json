{
    "name": "e2msolutions/postanalyzer",
    "description": "PostAnalyzer – Automated SEO, accessibility, and content QA audits for WordPress posts.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "PostAnalyzer\\": "includes/",
            "PostAnalyzer\\API\\": "api/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
